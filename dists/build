#!/usr/bin/env bash
set -euo pipefail
readonly red='\033[1;31m'
readonly green='\033[1;32m'
readonly blue='\033[1;34m'
readonly magenta='\033[1;35m'
readonly cyan='\033[1;36m'
readonly bright_white='\033[1;37m'
readonly bold='\033[1m'
readonly grey='\e[38;5;247;1;2;4m'
readonly nc='\033[0m' 
if command -v fc-list >/dev/null 2>&1 && fc-list | grep -qi "nerd font"; then
    readonly has_nerd_font=true
else
    readonly has_nerd_font=false
fi

if [[ "$has_nerd_font" == true ]]; then

    icon_debug=''
    icon_release=''
    icon_relwithdebinfo=''
    icon_minsizerel=''
    icon_arrow=''

    icon_deb=''
    icon_rpm=''
    icon_arch=''
    icon_mac=''
    icon_freebsd=''
    icon_tgz=''
    icon_appimage=''
    icon_all=''

    icon_profile=''
    icon_target=''
    icon_build=''
    icon_package=''
    icon_clean=''
    icon_success=''
    icon_failed=''
    icon_summary=''
    icon_folder=''
    icon_warning=''
else

    icon_debug=''
    icon_release=''
    icon_relwithdebinfo=''
    icon_minsizerel=''
    icon_arrow=''

    icon_deb=''
    icon_rpm=''
    icon_arch=''
    icon_mac=''
    icon_freebsd=''
    icon_tgz=''
    icon_appimage=''
    icon_all=''

    icon_profile=''
    icon_target=''
    icon_build=''
    icon_package=''
    icon_clean=''
    icon_success=''
    icon_failed=''
    icon_summary=''
    icon_folder=''
    icon_warning=''
fi

cat << "EOF"           
    ,----..                              
   /   /   \      ▁                       
  /   .     : ▝                   ▁   
 .   /   ;.  \      ,---,          ,--,  
.   ;   /  ` ;  ,-+-. /  |       ,'_ /|  
;   |  ; \ ; | ,--.'|'   |  .--. |  | :  
|   :  | ; | '|   |  ,"' |,'_ /| :  | .  
.   |  ' ' ' :|   | /  | ||  ' | |  . .  
'   ;  \; /  ||   | |  | ||  | ' |  | |  ▁
 \   \  ',  / |   | |  |/ :  | : ;  ; |  
  ;   :    /  |   | |--'  '  :  `--'   \ 
   \   \ .'   |   |/      :  ,      .-./ 
▖  `---`     '---'        `--`----'     ▁

EOF

if [[ "$has_nerd_font" == true ]]; then
    echo -e "                                               ${icon_package} pkg"
    echo -e "                                              ${icon_build} build,"
else
    echo -e "                                                 pkg"
    echo -e "                                               build,"
fi
echo -e "${bright_white}_______________________________________________________________________________________________________\n"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"
source "${SCRIPT_DIR}/CONF"

BUILD_TYPE="Release"
TARGETS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --options)

            profile_num="$2"
            target_num="$3"

            case $profile_num in
                1) BUILD_TYPE="Debug" ;;
                2) BUILD_TYPE="Release" ;;
                3) BUILD_TYPE="RelWithDebInfo" ;;
                4) BUILD_TYPE="MinSizeRel" ;;
                *) 
                    echo -e "${red}${icon_failed} Invalid profile number: $profile_num. Using default (Release)${nc}"
                    BUILD_TYPE="Release"
                    ;;
            esac

            case $target_num in
                1) TARGETS=(deb) ;;
                2) TARGETS=(rpm) ;;
                3) TARGETS=(arch) ;;
                4) TARGETS=(mac) ;;
                5) TARGETS=(freebsd) ;;
                6) TARGETS=(tgz) ;;
                7) TARGETS=(appimage) ;;
                8) TARGETS=(deb rpm arch mac freebsd tgz appimage) ;;
                *) 
                    echo -e "${red}${icon_failed} Invalid target number: $target_num. Using default (deb)${nc}"
                    TARGETS=(deb)
                    ;;
            esac

            shift 3
            ;;
        --clean) 
            echo -e "${bright_white}${icon_clean} Cleaning build directories...${nc}"
            rm -rf "${BUILD_DIR}" "${PKG_BUILD_BASE}"
            echo -e "${green}${icon_success} Clean complete.${nc}"
            exit 0 
            ;;
        *) 

            shift 
            ;;
    esac
done

if [[ ${#TARGETS[@]} -eq 0 ]]; then
    if [[ -t 1 ]]; then
        echo -e "\n\n${bright_white}${icon_profile} CMAKE PROFILE SELECTION${nc}"
        echo -e "____________________________________________________________________\n"
        echo -e "${icon_debug} ${bright_white}1>${nc} ${red}D${bright_white}ebug        ${grey}// Debug information contains compile info which may bigger the binary size;${nc}"
        echo -e "${icon_release} ${bright_white}2>${nc} ${green}R${bright_white}elease${nc}       ${grey}// Optimized for speed, no debug symbols, smallest binary;${nc}"
        echo -e "${icon_relwithdebinfo} ${bright_white}3>${nc} ${blue}R${bright_white}elease With Debug Info${nc} ${grey}// Optimized with debug symbols, best for profiling;${nc}"
        echo -e "${icon_minsizerel} ${bright_white}4>${nc} ${magenta}M${bright_white}inimum size release${nc}   ${grey}// Optimized for smallest binary size;${nc}"
        read -p "$(echo -e "${cyan}${icon_arrow} Select [2]: ${nc}")" p
        case $p in
            1) BUILD_TYPE="Debug" ;;
            3) BUILD_TYPE="RelWithDebInfo" ;;
            4) BUILD_TYPE="MinSizeRel" ;;
            *) BUILD_TYPE="Release" ;;
        esac

        echo -e "\n\n${bright_white}${icon_target} TARGET SELECTION${nc}"
        echo -e "____________________________________________________________________\n"
        echo -e "  ${icon_deb} ${bright_white}1>${nc} ${red}D${bright_white}eb${nc}    ${grey}// Debian and Ubuntu derivatives${nc}"
        echo -e "  ${icon_rpm} ${bright_white}2>${nc} ${green}R${bright_white}pm${nc}    ${grey}// Fedora, Red Hat Linux (RHEL)${nc}"
        echo -e "  ${icon_arch} ${bright_white}3>${nc} ${blue}A${bright_white}rch${nc}   ${grey}// Arch Linux and derivatives${nc}"
        echo -e "  ${icon_mac} ${bright_white}4>${nc} ${cyan}M${bright_white}ac${nc}     ${grey}// macOS packages (.pkg, .dmg)${nc} [ EXPERIMENTAL]"
        echo -e "  ${icon_freebsd} ${bright_white}5>${nc} ${red}F${bright_white}reebsd${nc} ${grey}// FreeBSD package${nc} [ EXPERIMENTAL]"
        echo -e "  ${icon_tgz} ${bright_white}6>${nc} ${magenta}T${bright_white}gz${nc}     ${grey}// Tar.gz archive${nc}"
        echo -e "  ${icon_appimage} ${bright_white}7>${nc} ${red}A${bright_white}ppimage${nc} ${grey}// AppImage (portable format for linux)${nc}"
        echo -e "  ${icon_all} ${bright_white}8>${nc} ${green}A${bright_white}LL${nc}     ${grey}// Build all package formats${nc}"
        echo -e  "\n\n${grey}keep eye on next version for more crossplatform support\n"
        read -p "$(echo -e "${cyan}${icon_arrow} Select [1]: ${nc}")" t
        case $t in
            1) TARGETS=(deb) ;;
            2) TARGETS=(rpm) ;;
            3) TARGETS=(arch) ;;
            4) TARGETS=(mac) ;;
            5) TARGETS=(freebsd) ;;
            6) TARGETS=(tgz) ;;
            7) TARGETS=(appimage) ;;
            8) TARGETS=(deb rpm arch mac freebsd tgz appimage) ;;
            *) TARGETS=(deb) ;;
        esac
    fi
fi

while IFS='=' read -r var _; do
    [[ "$var" =~ ^[A-Z_]+$ ]] && export "$var"
done < "${SCRIPT_DIR}/CONF"

echo -e "\n"
echo -e "${bright_white}${icon_build} Building with profile: ${green}${BUILD_TYPE}${nc}"
echo -e "${bright_white}${icon_target} Targets: ${bright_white}${TARGETS[*]}${nc}\n"
echo -e "\n____________________________________________________________________\n"

echo -e "${cyan}${icon_build} [BUILD]${nc} Configuring and compiling (${BUILD_TYPE})..."
cmake -S "${PROJECT_ROOT}" -B "${BUILD_DIR}" -DCMAKE_BUILD_TYPE="${BUILD_TYPE}"
cmake --build "${BUILD_DIR}" -j$(nproc 2>/dev/null || echo 4)
cmake --install "${BUILD_DIR}" --prefix "${STAGE_DIR}/usr"

SUCCESS=()
FAILED=()

for tgt in "${TARGETS[@]}"; do
    echo -e "${cyan}${icon_package} [PKG]${nc} Starting package build: ${bright_white}${tgt}${nc}"
    if bash "${DBS_DIR}/${tgt}.sh"; then
        if ls "${PKG_OUT}"/*${PKG_NAME}* >/dev/null 2>&1; then
            SUCCESS+=("$tgt")
            echo -e "  ${green}${icon_success} Success${nc}"
        else
            FAILED+=("$tgt")
            echo -e "  ${red}${icon_failed} Failed (package not found)${nc}"
        fi
    else
        FAILED+=("$tgt")
        echo -e "  ${red}${icon_failed} Failed (build error)${nc}"
    fi
done

echo -e "\n"
echo -e "${bright_white}${icon_summary} BUILD SUMMARY${nc}"
echo -e "\n____________________________________________________________________\n\n"
[[ ${#SUCCESS[@]} -gt 0 ]] && echo -e "${green} ${icon_success} Successful: ${SUCCESS[*]}${nc}"
[[ ${#FAILED[@]} -gt 0 ]] && echo -e "${red} ${icon_failed} Failed: ${FAILED[*]}${nc}"
echo -e "____________________________________Exit?  ${bright_white}:)${nc}"